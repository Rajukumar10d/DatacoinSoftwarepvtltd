# --- Server Configuration ---
# The port your Express server will run on. 5000 is a common choice for development.
PORT=5000

# --- MongoDB Configuration ---
# Your MongoDB connection string. Replace with your actual database connection details.
# For local MongoDB: MONGO_URI=mongodb://localhost:27017/your_database_name
# For MongoDB Atlas: 
# Using the Expanded String because your network cannot resolve SRV records (querySrv ECONNREFUSED)
MONGO_URI=mongodb+srv://rkt2classes_db_user:ROyae8c9TRJS2Kol@cluster0.uwxnetw.mongodb.net/?appName=Cluster0

# --- JSON Web Token (JWT) Configuration ---
# A long, complex, and random secret string used to sign and verify your JWTs.
# Keep this value private and secure. You can generate one using an online tool.
JWT_SECRET=your_super_secret_and_long_random_string_for_jwt

# --- CORS Configuration ---
# The URL of your frontend React application. This tells the server to accept requests from this origin.
# The default in your code is 'http://localhost:5173', which is common for Vite-based React apps.
# If your React app runs on a different port (like 3000), change it here.
CLIENT_URL=http://localhost:3000